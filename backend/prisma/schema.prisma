datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
  MANAGER
}

enum DeliveryState {
  RECEIVED
  QUEUED
  PROCESSING
  SUCCEEDED
  SKIPPED
  FAILED
}

enum ReviewRunState {
  QUEUED
  PROCESSING
  SUCCEEDED
  PARTIAL
  SKIPPED
  FAILED
}

enum FailureCategory {
  CONFIGURATION
  AUTHORIZATION
  RATE_LIMIT
  NOT_FOUND
  INVALID_RESPONSE
  VALIDATION
  STALE_COMMIT
  UPSTREAM
  TRANSIENT
  INTERNAL
}

enum FindingCategory {
  SECURITY
  POLICY
}

enum FindingSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PublicationState {
  PENDING
  POSTED
  SKIPPED
}

model User {
  id                 String                     @id @default(uuid())
  email              String                     @unique
  password           String
  name               String?
  role               Role                       @default(USER)
  repositoryAccesses GithubRepositoryAccess[]
  auditLogs          AuditLog[]
  evidenceExports    PullRequestEvidenceExport[]
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
}

model GithubWebhookDelivery {
  id              String           @id @default(uuid())
  deliveryId      String           @unique
  eventType       String
  state           DeliveryState    @default(RECEIVED)
  failureCategory FailureCategory?
  receivedAt      DateTime         @default(now())
  completedAt     DateTime?
  reviewRun       ReviewRun?

  @@index([state, receivedAt])
}

model GithubInstallation {
  id                   String             @id @default(uuid())
  githubInstallationId BigInt             @unique
  accountLogin         String?
  enabled              Boolean            @default(true)
  repositories         GithubRepository[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model GithubRepository {
  id                     String                      @id @default(uuid())
  githubRepositoryId     BigInt                      @unique
  installationId         String
  installation           GithubInstallation          @relation(fields: [installationId], references: [id], onDelete: Cascade)
  owner                  String
  name                   String
  fullName               String
  enabled                Boolean                     @default(true)
  ruleConfiguration      Json                        @default("{}")
  draftPullRequestPolicy String                      @default("SKIP")
  checkRunMode           String                      @default("ADVISORY")
  llmReviewEnabled       Boolean                     @default(false)
  llmModel               String                      @default("gpt-5.6-sol")
  retentionDays          Int                         @default(90)
  reviewRuns             ReviewRun[]
  accessGrants           GithubRepositoryAccess[]
  auditLogs              AuditLog[]
  evidenceExports        PullRequestEvidenceExport[]
  precisionSnapshots     PilotPrecisionSnapshot[]
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt

  @@index([installationId, enabled])
  @@index([fullName])
}

model ReviewRun {
  id                     String                @id @default(uuid())
  deliveryId             String                @unique
  delivery               GithubWebhookDelivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  repositoryId           String
  repository             GithubRepository      @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  pullRequestNumber      Int
  headSha                String
  ruleConfiguration      Json                  @default("{}")
  state                  ReviewRunState        @default(QUEUED)
  attemptCount           Int                   @default(0)
  maxAttempts            Int                   @default(3)
  nextAttemptAt          DateTime              @default(now())
  retryable              Boolean               @default(true)
  failureCategory        FailureCategory?
  failureMessage         String?
  checkRunId             BigInt?
  checkRunUrl            String?
  checkRunStatus         String?
  checkRunConclusion     String?
  reviewSummary          String?
  llmState               String                @default("SKIPPED")
  llmFailureMessage      String?
  rerunReason            String?
  rerunRequestedByUserId String?
  startedAt              DateTime?
  completedAt            DateTime?
  analyzedFileCount      Int                   @default(0)
  skippedFileCount       Int                   @default(0)
  findingCount           Int                   @default(0)
  suppressedFindingCount Int                   @default(0)
  findings               Finding[]
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  @@index([state, nextAttemptAt])
  @@index([repositoryId, pullRequestNumber, createdAt])
  @@index([repositoryId, pullRequestNumber, headSha])
}

model Finding {
  id                String           @id @default(uuid())
  reviewRunId       String
  reviewRun         ReviewRun        @relation(fields: [reviewRunId], references: [id], onDelete: Cascade)
  fingerprint       String
  ruleId            String
  ruleVersion       String
  source            String           @default("DETERMINISTIC")
  category          FindingCategory
  severity          FindingSeverity
  confidence        Float
  filePath          String
  lineNumber        Int
  title             String
  evidence          String
  explanation       String
  remediation       String
  suppressed        Boolean          @default(false)
  suppressionReason String?
  pilotVerification String?
  pilotVerifiedAt   DateTime?
  pilotVerifiedBy   String?
  pilotNotes        String?
  publicationState  PublicationState @default(PENDING)
  githubCommentId   BigInt?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([reviewRunId, fingerprint])
  @@index([reviewRunId, suppressed, severity])
}

model GithubRepositoryAccess {
  id           String           @id @default(uuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  repositoryId String
  repository   GithubRepository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  role         String           @default("VIEWER")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([userId, repositoryId])
  @@index([repositoryId, role])
}

model AuditLog {
  id           String            @id @default(uuid())
  userId       String?
  user         User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  repositoryId String?
  repository   GithubRepository? @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
  action       String
  metadata     Json              @default("{}")
  createdAt    DateTime          @default(now())

  @@index([repositoryId, createdAt])
  @@index([userId, createdAt])
}

model PullRequestEvidenceExport {
  id                String           @id @default(uuid())
  repositoryId      String
  repository        GithubRepository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  requestedByUserId String?
  requestedBy       User?            @relation(fields: [requestedByUserId], references: [id], onDelete: SetNull)
  pullRequestNumber Int
  headSha           String?
  filename          String
  markdown          String
  markdownSha256    String
  version           Int              @default(1)
  createdAt         DateTime         @default(now())

  @@unique([repositoryId, pullRequestNumber, version])
  @@index([repositoryId, pullRequestNumber, createdAt])
}

model PilotPrecisionSnapshot {
  id                 String           @id @default(uuid())
  repositoryId       String
  repository         GithubRepository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  ruleId             String
  totalFindings      Int
  confirmedCount     Int
  falsePositiveCount Int
  unverifiedCount    Int
  precision          Float
  snapshotAt         DateTime         @default(now())

  @@index([repositoryId, ruleId, snapshotAt])
}
